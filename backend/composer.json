{
    "name": "facturacion/backend",
    "description": "Backend para sistema de facturación",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5",
        "bramus/router": "^1.6",
        "firebase/php-jwt": "^7.0",
        "symfony/yaml": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
